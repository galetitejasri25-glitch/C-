bool compareStacks(Stack& s1, Stack& s2) {
    if (s1.isEmpty() && s2.isEmpty()) {
        return true;
    }
    if (s1.isEmpty() || s2.isEmpty()) {
        return false;
    }
    while (!s1.isEmpty() && !s2.isEmpty()) {
        if (s1.peek() != s2.peek()) {
            return false;
        }
        s1.pop();
        s2.pop();
    }
    return s1.isEmpty() && s2.isEmpty();
}
