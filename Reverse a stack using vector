#include <iostream>
#include <stack>
#include <vector>

void reverseVector(std::vector<int>& vec) {
    std::stack<int> s;
    for (int i : vec) {
        s.push(i);
    }
    for (int i = 0; i < vec.size(); i++) {
        vec[i] = s.top();
        s.pop();
    }
}

int main() {
    std::vector<int> vec = {1, 2, 3, 4, 5};
    reverseVector(vec);
    for (int i : vec) {
        std::cout << i << " ";
    }
    return 0;
}
