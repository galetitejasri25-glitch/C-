#include <iostream>
using namespace std;

void selectionSortMax(int arr[], int n) {
    // One by one move the boundary of the unsorted subarray
    for (int i = n - 1; i > 0; i--) {
        // Find the maximum element in unsorted array [0...i]
        int max_idx = 0;
        for (int j = 1; j <= i; j++) {
            if (arr[j] > arr[max_idx]) {
                max_idx = j;
            }
        }

        // Swap the found maximum element with the last element
        int temp = arr[max_idx];
        arr[max_idx] = arr[i];
        arr[i] = temp;
        
        cout << "Pass " << (n - i) << ": ";
        for(int k=0; k<n; k++) cout << arr[k] << " ";
        cout << endl;
    }
}

int main() {
    int arr[] = {29, 10, 14, 37, 13};
    int n = sizeof(arr)/sizeof(arr[0]);

    cout << "Original array: ";
    for(int i=0; i<n; i++) cout << arr[i] << " ";
    cout << "\n\nSorting process:\n";

    selectionSortMax(arr, n);

    cout << "\nSorted array: ";
    for(int i=0; i<n; i++) cout << arr[i] << " ";
    
    return 0;
}
