#include <iostream>
#include <vector>

void reverseVector(std::vector<int>& vec) {
    int left = 0, right = vec.size() - 1;
    while (left < right) {
        std::swap(vec[left], vec[right]);
        left++;
        right--;
    }
}

int main() {
    std::vector<int> vec = {1, 2, 3, 4, 5};
    reverseVector(vec);
    for (int i : vec) {
        std::cout << i << " ";
    }
    return 0;
}

