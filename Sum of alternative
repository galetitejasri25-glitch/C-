#include <iostream>
using namespace std;

void sumAlternate(int arr[], int n) {
    int sum = 0;

    cout << "Alternate elements being added: ";
    
    // Increment the loop by 2 in each step to skip one element
    for (int i = 0; i < n; i += 2) {
        cout << arr[i] << " ";
        sum += arr[i];
    }

    cout << "\nTotal Sum of Alternate Elements: " << sum << endl;
}

int main() {
    int arr[] = {10, 20, 30, 40, 50, 60, 70};
    int n = sizeof(arr) / sizeof(arr[0]);

    cout << "Original Array: ";
    for (int i = 0; i < n; i++) cout << arr[i] << " ";
    cout << endl << endl;

    sumAlternate(arr, n);

    return 0;
}
