#include <iostream>
using namespace std;

void sumOddNumbers(int arr[], int n) {
    int sum = 0;
    bool foundOdd = false;

    cout << "Odd numbers found: ";
    for (int i = 0; i < n; i++) {
        // Check if the current element is odd
        if (arr[i] % 2 != 0) {
            cout << arr[i] << " ";
            sum += arr[i];
            foundOdd = true;
        }
    }

    if (!foundOdd) {
        cout << "None";
    }

    cout << "\nTotal Sum of Odd Numbers: " << sum << endl;
}

int main() {
    int arr[] = {12, 7, 15, 20, 33, 8, 5};
    int n = sizeof(arr) / sizeof(arr[0]);

    cout << "Original Array: ";
    for (int i = 0; i < n; i++) cout << arr[i] << " ";
    cout << endl << endl;

    sumOddNumbers(arr, n);

    return 0;
}
