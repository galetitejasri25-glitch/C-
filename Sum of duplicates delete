#include <iostream>
using namespace std;

struct Node {
    int data;
    Node* next;
};

// Function to remove duplicates and return the sum of deleted values
int sumDeletedDuplicates(Node* head) {
    if (head == NULL) return 0;

    int sum = 0;
    Node* current = head;

    // Traverse the list
    while (current->next != NULL) {
        // Check if current node and next node have the same data
        if (current->data == current->next->data) {
            Node* nextNext = current->next->next; // Save the link to the rest of the list
            
            sum += current->next->data;           // Add duplicate value to sum
            cout << "Duplicate found: " << current->next->data << " (Adding to sum)" << endl;
            
            delete current->next;                 // Delete the duplicate node
            current->next = nextNext;             // Reconnect the list
        } else {
            current = current->next;              // Move to the next node only if no duplicate was found
        }
    }
    return sum;
}

// Helper to insert at end
void insert(Node** head, int val) {
    Node* newNode = new Node();
    newNode->data = val;
    newNode->next = NULL;
    if (*head == NULL) { *head = newNode; return; }
    Node* temp = *head;
    while (temp->next != NULL) temp = temp->next;
    temp->next = newNode;
}

int main() {
    Node* head = NULL;
    // Creating a list with duplicates: 10 -> 20 -> 20 -> 30 -> 30
    insert(&head, 10);
    insert(&head, 20);
    insert(&head, 20);
    insert(&head, 30);
    insert(&head, 30);

    cout << "Original List: 10 -> 20 -> 20 -> 30 -> 30" << endl;

    int totalDeletedSum = sumDeletedDuplicates(head);

    cout << "\nTotal Sum of Duplicates Deleted: " << totalDeletedSum << endl;

    return 0;
}
