#include <iostream>
using namespace std;

struct Node {
    int data;
    Node* next;
};

int main() {
    Node *head = NULL, *temp = NULL, *newNode = NULL;
    int choice = 1;

    // Use a while loop to keep adding nodes
    while (choice == 1) {
        newNode = new Node(); // Create a new node in memory
        
        cout << "Enter data for the node: ";
        cin >> newNode->data;
        newNode->next = NULL;

        if (head == NULL) {
            head = newNode; // First node becomes the head
            temp = newNode;
        } else {
            temp->next = newNode; // Link previous node to new node
            temp = newNode;       // Move temp to the new last node
        }

        cout << "Press 1 to add another node, 0 to stop: ";
        cin >> choice;
    }

    // Displaying the list created
    cout << "\nFinal Linked List: ";
    temp = head;
    while (temp != NULL) {
        cout << temp->data << " -> ";
        temp = temp->next;
    }
    cout << "NULL" << endl;

    return 0;
}
